# ===================================================================
# ARIS — Exemplo de configuração de ambiente
# Copie este arquivo para `.env` e preencha com seus valores reais.
# O `.env` NUNCA deve ser commitado (está no .gitignore).
# ===================================================================

# --- APIs externas ---
# Chave da API do Google AI Studio (https://aistudio.google.com) — usada pelo Gemini
GEMINI_KEY=
# Chave da API OpenWeather (https://openweathermap.org/api) — clima/previsão
OPENWEATHER_KEY=

# --- Motor de raciocínio (LLM) ---
# Provider do cérebro do ARIS: "gemini" (nuvem) ou "ollama" (local)
ARIS_LLM_PROVIDER=gemini
# Modelo do Gemini (rode genai.list_models() para ver os disponíveis na sua chave)
GEMINI_MODEL=gemini-2.5-flash
# Configuração do Ollama (usado apenas quando ARIS_LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Localização ---
CIDADE_PADRAO=São Paulo

# --- Síntese de voz (TTS) ---
TTS_ENGINE=edge
EDGE_TTS_VOICE=pt-BR-AntonioNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz
EDGE_TTS_VOLUME=+0%
# Efeito de eco/reverb (0 = desligado)
EDGE_TTS_ECHO_DELAY_MS=0
EDGE_TTS_ECHO_VOLUME=0
EDGE_TTS_ECHO2_DELAY_MS=0
EDGE_TTS_ECHO2_VOLUME=0

# --- Controle de volume por app ---
# Processos de navegador cujo volume o ARIS ajusta ao falar "volume do YouTube"
YOUTUBE_VOLUME_APPS=msedge.exe,msedgewebview2.exe,chrome.exe,brave.exe,opera.exe,firefox.exe

# --- Atalhos de apps/redes sociais ---
INSTAGRAM_HANDLE=
INSTAGRAM_APP_ID=
FACEBOOK_APP_ID=
FACEBOOK_PROFILE=
# Caminho absoluto para WINWORD.EXE (opcional, se a detecção automática falhar)
WORD_PATH=

# --- Playlists (YouTube) ---
PLAYLIST_MUSICA=
PLAYLIST_ESTUDO=
PLAYLIST_TREINO=
